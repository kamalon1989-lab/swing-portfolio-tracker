# Firebase 설정 — 비워두면 lib/firebase.ts의 기본값(legacy와 동일) 사용.
# Vercel 대시보드에서 Environment Variables로 설정하면 그 값이 우선.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DB_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Phase 3 — 서버 사이드 시크릿 (필수). NEXT_PUBLIC_ 접두사 없으므로 클라이언트에 노출 안 됨.
# Vercel Settings → Environment Variables 에 동일 이름으로 등록.
# 로컬 개발 시에는 .env.local 만들어서 같은 변수 넣기.
FINNHUB_API_KEY=
